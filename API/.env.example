# Banco (host "db" = serviço no compose; em AWS vira o endpoint do RDS)
DATABASE_URL=postgresql+psycopg://mnemo:mnemo@db:5432/mnemo

# Whisper: tiny | base | small | medium | large
WHISPER_MODEL=base

# IA / flashcards (Anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Segurança
MAX_UPLOAD_MB=200

# Debug (false em produção)
DEBUG=false
LOG_LEVEL=INFO

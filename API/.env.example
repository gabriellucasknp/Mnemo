# Modelo de variáveis de ambiente. Copie para um arquivo ".env" (que NÃO vai pro
# git) e ajuste os valores:  cp API/.env.example API/.env

# --- Banco (Etapa 4) ---
# Host "db" = nome do serviço no compose. Dentro da rede do Docker, é assim que
# a API enxerga o Postgres (NÃO use localhost entre containers).
DATABASE_URL=postgresql+psycopg://mnemo:mnemo@db:5432/mnemo

# --- Whisper (Etapa 2/3) ---
# tiny | base | small | medium | large — "base" = equilíbrio pro MVP na CPU.
WHISPER_MODEL=base

# --- IA / flashcards (Etapa 5) — Anthropic (Claude) ---
# Crie a chave em https://platform.claude.com/ e cole aqui:
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- Segurança ---
# Teto de upload de áudio, em MB (proteção contra requests gigantes).
MAX_UPLOAD_MB=200
